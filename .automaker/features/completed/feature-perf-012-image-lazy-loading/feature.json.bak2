\\board-view.tsx\",\n  \"offset\": 2308,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:13.390Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/feature-image-upload.tsx'\"\n}\n\n[timestamp:2026-02-12T22:08:13.537Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/description-image-dropzone.tsx'\"\n}\n\n[timestamp:2026-02-12T22:08:13.701Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/image-drop-zone.tsx'\"\n}\n\n[timestamp:2026-02-12T22:08:15.735Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\dashboard-view.tsx\",\n  \"offset\": 774,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:16.038Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\dashboard-view.tsx\",\n  \"offset\": 865,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:17.414Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\github-issues-view\\\\components\\\\comment-item.tsx\",\n  \"offset\": 11,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:17.609Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\github-issues-view\\\\components\\\\issue-detail-panel.tsx\",\n  \"offset\": 224,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:17.862Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\project-settings-view\\\\project-identity-section.tsx\",\n  \"offset\": 198,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:18.103Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\settings-view\\\\components\\\\edit-project-dialog.tsx\",\n  \"offset\": 205,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:55.709Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\settings-view\\\\projects\\\\projects-section.tsx\",\n  \"offset\": 512,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:56.033Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\setup-view\\\\steps\\\\welcome-step.tsx\",\n  \"offset\": 7,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:56.415Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\setup-view.tsx\",\n  \"offset\": 94,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:08:58.983Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\welcome-view.tsx\",\n  \"offset\": 549,\n  \"limit\": 10\n}\n\n[timestamp:2026-02-12T22:09:28.345Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/lib/utils.ts' | head -30\"\n}\n\n[timestamp:2026-02-12T22:09:28.574Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/image-preview-dialog.tsx'\"\n}\n\n[timestamp:2026-02-12T22:09:28.970Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/dialog.tsx'\"\n}\n\n[timestamp:2026-02-12T22:09:57.596Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"find '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src' -name '*skeleton*' -o -name '*loader*' | head -20\"\n}\n\n[timestamp:2026-02-12T22:09:57.869Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/lib/image-utils.ts' | head -100\"\n}\n\n[timestamp:2026-02-12T22:10:13.192Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/views/board-view/components/board-skeleton.tsx'\"\n}\n\n[timestamp:2026-02-12T22:10:13.972Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/views/board-view/components/kanban-card/feature-card-skeleton.tsx'\"\n}\n\n[timestamp:2026-02-12T22:10:40.328Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/input.tsx'\"\n}\n\n[timestamp:2026-02-12T22:10:40.679Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/textarea.tsx'\"\n}\n\n[timestamp:2026-02-12T22:11:12.285Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"cat '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/ui/dropdown-menu.tsx' | head -150\"\n}\n\n[timestamp:2026-02-12T22:11:36.078Z] 🔧 Tool: Bash\nInput: {\n  \"command\": \"ls -la '/c/Users/DylanSmart/Downloads/automaker-pr/apps/ui/src/components/' | grep -E \\\"index|layout\\\"\"\n}\nNow let me look at a few specific files to understand the exact code patterns:\n\n[timestamp:2026-02-12T22:12:23.435Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\views\\\\board-view\\\\components\\\\kanban-card\\\\card-content-sections.tsx\"\n}\n\n[timestamp:2026-02-12T22:12:24.141Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\components\\\\ui\\\\image-preview-dialog.tsx\"\n}\n\n[timestamp:2026-02-12T22:12:24.576Z] 🔧 Tool: Read\nInput: {\n  \"file_path\": \"C:\\\\Users\\\\DylanSmart\\\\Downloads\\\\automaker-pr\\\\apps\\\\ui\\\\src\\\\lib\\\\utils.ts\"\n}\nNow I have a thorough understanding of the codebase. Note that `card-content-sections.tsx` doesn't actually contain any `<img>` tags - it only has branch and PR link info. Let me now produce the specification.\n\n---\n\n## 1. Problem Statement\n\nAll `<img>` tags across the Automaker UI render without `loading=\"lazy\"`, skeleton placeholders, or error handling. Off-screen images (e.g., in scrolled-away kanban cards, project lists) load immediately on render, increasing initial bandwidth and degrading page load performance. When images fail to load, users see broken image icons with no graceful fallback.\n\n## 2. User Story\n\nAs a **developer using Automaker**, I want **images to load lazily with skeleton placeholders and error fallbacks**, so that **the UI loads faster, uses less bandwidth, and handles image failures gracefully**.\n\n## 3. Acceptance Criteria\n\n- **Happy Path - Lazy Loading**: GIVEN a board with 20+ feature cards containing images, WHEN the page loads, THEN only images visible in the viewport are fetched; off-screen images load as the user scrolls to them.\n- **Happy Path - Skeleton**: GIVEN an image is still loading, WHEN the component renders, THEN a pulsing skeleton placeholder with matching dimensions is displayed.\n- **Happy Path - Loaded**: GIVEN an image has loaded successfully, WHEN the load completes, THEN the skeleton fades away and the image fades in smoothly.\n- **Error Handling**: GIVEN an image URL returns a 404 or fails to load, WHEN the error event fires, THEN a muted fallback with an `ImageOff` icon is displayed instead of a broken image icon.\n- **Edge Case - Preview Dialog**: GIVEN a user clicks an image to open the preview dialog, WHEN the dialog opens, THEN the full-size image still loads and displays correctly (preview dialog images should NOT be lazy since they're always in-view).\n- **Edge Case - Inline Data URLs**: GIVEN an image uses a base64 data URL (file upload previews), WHEN the component renders, THEN the image loads instantly without a visible skeleton flash (data URLs are already local).\n- **Edge Case - Logo Images**: GIVEN static logo images like `/logo.png`, WHEN the page loads, THEN these are NOT made lazy (they're critical above-the-fold content).\n- **Edge Case - No CLS**: GIVEN images have `LazyImage` applied, WHEN loading completes, THEN there is no Cumulative Layout Shift because containers have defined dimensions or aspect ratios.\n\n## 4. Technical Context\n\n| Aspect | Value |\n|--------|-------|\n| Affected Files | 16 files (14 with `<img>` tags + 1 new component + 1 barrel export) |\n| Dependencies | None (uses native `loading=\"lazy\"`, React state, existing lucide-react icons) |\n| Constraints | Must not break existing click-to-preview functionality; must work with `getAuthenticatedImageUrl()` |\n| Patterns to Follow | `cn()` from `@/lib/utils`, `data-slot` attribute, lucide-react icons, `animate-pulse` skeletons, `bg-muted` for placeholder colors |\n\n## 5. Non-Goals\n\n- **Intersection Observer polyfill**: Native `loading=\"lazy\"` has sufficient browser support; no need for a JS-based lazy loading library.\n- **Blur-up / LQIP placeholders**: No low-quality image placeholder technique; a simple skeleton is sufficient.\n- **Image optimization / resizing**: No server-side image processing or srcset generation.\n- **Virtualized image lists**: No virtual scrolling for image-heavy lists (separate concern).\n- **Retry logic**: No automatic retry on failed image loads.\n\n## 6. Implementation Tasks\n\n```tasks\n## Phase 1: Foundation\n- [ ] T001: Create reusable LazyImage component with loading/error states | File: apps/ui/src/components/ui/lazy-image.tsx\n- [ ] T002: Export LazyImage from UI component barrel (if one exists) or verify import path works | File: apps/ui/src/components/ui/lazy-image.tsx\n\n## Phase 2: Core Replacements - Board & Dashboard Views\n- [ ] T003: Replace <img> tags in board-view.tsx (2 project icon instances) with LazyImage | File: apps/ui/src/components/views/board-view.tsx\n- [ ] T004: Replace <img> tags in dashboard-view.tsx (2 project icon instances) with LazyImage | File: apps/ui/src/components/views/dashboard-view.tsx\n- [ ] T005: Replace <img> tag in agent-chat-panel.tsx (2 project icon instances) with LazyImage | File: apps/ui/src/components/views/board-view/components/agent-chat-panel.tsx\n\n## Phase 3: Core Replacements - Agent & Settings Views\n- [ ] T006: Replace <img> tag in session-selector.tsx (1 project icon) with LazyImage | File: apps/ui/src/components/views/agent-view/components/session-selector.tsx\n- [ ] T007: Replace <img> tag in message-bubble.tsx (1 chat image) with LazyImage | File: apps/ui/src/components/views/agent-view/components/message-bubble.tsx\n- [ ] T008: Replace <img> tag in project-identity-section.tsx (1 project icon preview) with LazyImage | File: apps/ui/src/components/views/project-settings-view/project-identity-section.tsx\n- [ ] T009: Replace <img> tag in edit-project-dialog.tsx (1 project icon) with LazyImage | File: apps/ui/src/components/views/settings-view/components/edit-project-dialog.tsx\n- [ ] T010: Replace <img> tag in projects-section.tsx (1 project icon) with LazyImage | File: apps/ui/src/components/views/settings-view/projects/projects-section.tsx\n\n## Phase 4: Core Replacements - Image Upload & Dropzone Components\n- [ ] T011: Replace <img> tags in description-image-dropzone.tsx (2 thumbnail instances) with LazyImage | File: apps/ui/src/components/ui/description-image-dropzone.tsx\n- [ ] T012: Replace <img> tag in feature-image-upload.tsx (1 thumbnail) with LazyImage | File: apps/ui/src/components/ui/feature-image-upload.tsx\n- [ ] T013: Replace <img> tag in image-drop-zone.tsx (1 thumbnail) with LazyImage | File: apps/ui/src/components/ui/image-drop-zone.tsx\n- [ ] T014: Replace <img> tag in file-preview.tsx (1 file preview thumbnail) with LazyImage | File: apps/ui/src/components/views/agent-view/input-area/file-preview.tsx\n\n## Phase 5: Remaining Views & Edge Cases\n- [ ] T015: Replace <img> tags in GitHub components (comment-item.tsx, issue-detail-panel.tsx) with LazyImage | File: apps/ui/src/components/views/github-issues-view/components/comment-item.tsx\n- [ ] T016: Add error handling to image-preview-dialog.tsx (keep eager loading, add onError fallback) | File: apps/ui/src/components/ui/image-preview-dialog.tsx\n- [ ] T017: Add error handling to board-background-modal.tsx background preview image | File: apps/ui/src/components/dialogs/board-background-modal.tsx\n- [ ] T018: Skip LazyImage for static logos (welcome-step.tsx, setup-view.tsx, welcome-view.tsx) - just add loading=\"eager\" to be explicit | File: apps/ui/src/components/views/setup-view/steps/welcome-step.tsx\n\n## Phase 6: Validation\n- [ ] T019: Build the project to verify no TypeScript errors | File: (build output)\n```\n\n## 7. Success Metrics\n\n- All 24 `<img>` tags are either replaced with `LazyImage` or explicitly marked with `loading=\"eager\"` for above-the-fold content.\n- The project builds without TypeScript errors.\n- Off-screen images in the kanban board defer loading until scrolled into view (verifiable via browser DevTools Network tab).\n- Failed image loads display a muted `ImageOff` icon instead of a broken image icon.\n- Images show a pulsing skeleton placeholder while loading.\n- No layout shift when images load (containers maintain their dimensions).\n\n## 8. Risks & Mitigations\n\n| Risk | Mitigation |\n|------|------------|\n| LazyImage wrapper breaks click-to-preview interactions | Pass through all event handlers via `...props` spread; test preview dialog still opens |\n| Skeleton flash on instant-loading data URLs | Data URLs trigger `onLoad` synchronously or near-instantly; the opacity transition is short enough (200ms) that any flash is imperceptible |\n| Layout shift from missing dimensions | LazyImage wrapper inherits parent container dimensions via `className`; existing containers already define dimensions (e.g., `w-5 h-5`, `w-full h-full`) |\n| Image-preview-dialog shows skeleton unnecessarily | Preview dialog keeps `<img>` directly with just error handling added, no lazy loading |\n| Authenticated image URLs don't work with lazy loading | `loading=\"lazy\"` is a browser-native attribute that works with any URL including authenticated ones; no impact |\n\n---",
